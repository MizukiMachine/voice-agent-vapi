# ============================================================
# Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control
# ============================================================

# ============================================================
# Node.js Version Requirement
# ============================================================
# IMPORTANT: This project requires Node.js v22.22.0 or higher
# Using an older version will cause AsyncLocalStorage errors (CVE-2025-59466)
#
# To install the correct version:
#   nvm install 22.22.0
#   nvm use 22.22.0
#
# Or download from: https://nodejs.org/
# ============================================================

# ============================================================
# Client-Side Variables (NEXT_PUBLIC_* prefix)
# ============================================================
# These variables are exposed to the browser and can be used in client-side code

# Supabase (Anon Key is protected by RLS policies)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WebSocket URL (for dual-server architecture)
# Development: ws://localhost:3001/api/webrtc
# Production: wss://your-domain.com/api/webrtc
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3001/api/webrtc

# ============================================================
# Server-Side Variables (NOT exposed to browser)
# ============================================================

# Supabase Service Role Key (bypasses RLS, never commit to git)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Vapi Configuration (Voice AI Platform)
VAPI_API_KEY=your-vapi-api-key
VAPI_PUBLIC_KEY=your-vapi-public-key
VAPI_ASSISTANT_ID=your-assistant-id

# Cartesia Configuration (TTS Provider)
CARTESIA_API_KEY=your-cartesia-api-key
CARTESIA_VOICE_ID=79a125e6-c5a2-4b9d-8b3f-5c2a1b2d3e4f
CARTESIA_DEFAULT_SPEED=1.0
CARTESIA_SAMPLE_RATE=24000
CARTESIA_OUTPUT_FORMAT=pcm16

# ============================================================
# Server Configuration
# ============================================================

# Node Environment
NODE_ENV=development

# Server Port (Next.js)
PORT=3000

# Server Hostname
HOSTNAME=localhost

# WebSocket Port (for dual-server architecture)
WEBSOCKET_PORT=3001

# ============================================================
# Optional: Google Cloud Integration
# ============================================================
# Uncomment and fill if using Google Calendar/Docs integration

# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REFRESH_TOKEN=your-google-refresh-token
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================================
# Optional: Development Tools
# ============================================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Enable debug mode
DEBUG=false

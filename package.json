{
  "name": "voice-engine-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "dev:next": "dotenvx run --convention=nextjs -- next dev",
    "dev:plain": "next dev",
    "build": "next build",
    "build:plain": "next build",
    "start": "NODE_ENV=production ts-node src/server.ts",
    "start:next": "dotenvx run --convention=nextjs -- next start",
    "start:plain": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:migrate": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "db:types": "npx supabase gen types typescript --local > types/database.ts",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "dotenvx:encrypt": "dotenvx encrypt",
    "dotenvx:decrypt": "dotenvx decrypt",
    "dotenvx:set": "dotenvx set",
    "create-assistant": "tsx scripts/create-vapi-assistant.ts"
  },
  "dependencies": {
    "@cartesia/cartesia-js": "^1.2.0",
    "@supabase/supabase-js": "^2.91.0",
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "werift": "^0.22.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.11",
    "@swc/register": "^0.1.10",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.13",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "node-mocks-http": "^1.17.2",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.0",
    "supabase": "^2.76.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}

# ============================================================
# Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# ============================================================
# Safe to make public (client-side - NEXT_PUBLIC_* prefix)
# ============================================================

# Supabase (Anon Key is protected by RLS, public by design)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL (deployment URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# MUST NOT BE MADE PUBLIC (server-side only)
# ============================================================

# Supabase (Service Role Key - bypasses RLS, never public)
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Voice AI Infrastructure (Vapi + Cartesia)
# ============================================================

# Vapi Platform (STT + LLM + Function Calling)
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# Cartesia (TTS with speed control + custom voice)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=79a125e8-cd45-4c05-9a83-4b0d4b0f3c29
CARTESIA_DEFAULT_SPEED=1.0
CARTESIA_SAMPLE_RATE=24000
CARTESIA_OUTPUT_FORMAT=pcm16

# ============================================================
# WebRTC Configuration (Optional)
# ============================================================

# ICE Servers for NAT traversal (STUN/TURN)
# Default: Google's public STUN servers
# ICE_SERVER_URLS=stun:stun.l.google.com:19302
# ICE_USERNAME=
# ICE_CREDENTIAL=

# WebRTC Session Timeout (milliseconds)
# WEBRTC_SESSION_TIMEOUT=300000

# Audio Processing Configuration
# AUDIO_INPUT_SAMPLE_RATE=16000
# AUDIO_OUTPUT_SAMPLE_RATE=24000
# AUDIO_CHUNK_DURATION_MS=20

# ============================================================
# OpenAI (LLM for tool execution - optional, Vapi can handle)
# ============================================================

OPENAI_API_KEY=

# ============================================================
# Google Cloud (for tool execution)
# ============================================================

# Google Maps (Places API / Geocoding API)
GOOGLE_MAPS_API_KEY=

# Google OAuth (for Calendar/Docs - optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
